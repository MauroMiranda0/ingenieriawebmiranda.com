jsonld: |
  {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Solicitar diagnóstico técnico",
      "url": "https://ingenieriawebmiranda.com/contacto/",
      "description": "Formulario para solicitar diagnósticos técnicos y evaluar riesgos, oportunidades y próximos pasos.",
      "publisher": {
        "@type": "Organization",
        "name": "Ingeniería Web Miranda"
      }
    }
---

<main class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid lg:grid-cols-12 gap-10 items-start">
    <div class="lg:col-span-5">
      <p class="text-xs tracking-[0.3em] uppercase opacity-60 mb-4">Contacto</p>
      <h1 class="font-display text-5xl md:text-6xl text-primary mb-6">Solicitar diagnóstico técnico</h1>
      <p class="text-lg text-slate-600 leading-relaxed mb-10">
        Cuéntanos tu contexto. Responderemos con claridad: riesgos, oportunidades y siguiente paso defendible.
      </p>

      <div class="space-y-4 text-sm text-slate-600">
        <p>
          <span class="material-icons align-middle text-primary mr-2">schedule</span>
          Respuesta en menos de 24 horas
        </p>
        <p>
          <span class="material-icons align-middle text-primary mr-2">lock</span>
          Confidencialidad por defecto
        </p>
        <p>
          <span class="material-icons align-middle text-primary mr-2">rule</span>
          Sin improvisación: decisiones documentadas
        </p>
      </div>
    </div>

    <div class="lg:col-span-7">
      <form
        class="border border-slate-200 bg-white/70 p-10 space-y-6"
        action="https://formspree.io/f/xpqjevwp"
        method="POST">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="text-xs tracking-widest uppercase opacity-60">Nombre</label>
            <input
              class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
              type="text"
              name="nombre"
              placeholder="Tu nombre"
              required />
          </div>
          <div>
            <label class="text-xs tracking-widest uppercase opacity-60">Email</label>
            <input
              class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
              type="email"
              name="email"
              placeholder="tu@email.com"
              required />
          </div>
          <div>
            <label class="text-xs tracking-widest uppercase opacity-60">Teléfono</label>
            <input
              class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
              type="tel"
              name="telefono"
              placeholder="+52 55 1234 5678" />
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="text-xs tracking-widest uppercase opacity-60">Organización (opcional)</label>
            <input
              class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
              type="text"
              name="organizacion"
              placeholder="Empresa o proyecto" />
          </div>
          <div>
            <label class="text-xs tracking-widest uppercase opacity-60">Tipo de necesidad</label>
            <select
              class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
              name="tipo">
              <option value="Diagnóstico">Diagnóstico</option>
              <option value="Modernización">Modernización</option>
              <option value="Performance">Performance</option>
              <option value="Sistema web">Sistema web</option>
            </select>
          </div>
        </div>

        <div>
          <label class="text-xs tracking-widest uppercase opacity-60">Describe el reto / objetivo</label>
          <textarea
            class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
            rows="5"
            placeholder="¿Qué quieres lograr? ¿Qué te preocupa? ¿Qué no está funcionando?"
            name="mensaje"
            required></textarea>
        </div>

        <div>
          <p class="text-xs tracking-widest uppercase opacity-60">Método preferido de contacto</p>
          <div class="mt-3 grid gap-3 sm:grid-cols-3">
            <label
              class="flex items-center gap-3 border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:border-primary transition-colors cursor-pointer">
              <input
                class="h-4 w-4 text-primary border-slate-300 focus:ring-primary"
                type="radio"
                name="metodo_preferido"
                value="Email"
                checked
                required />
              <span>Email</span>
            </label>
            <label
              class="flex items-center gap-3 border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:border-primary transition-colors cursor-pointer">
              <input
                class="h-4 w-4 text-primary border-slate-300 focus:ring-primary"
                type="radio"
                name="metodo_preferido"
                value="Llamada telefónica" />
              <span>Llamada telefónica</span>
            </label>
            <label
              class="flex items-center gap-3 border border-slate-200 rounded-lg px-4 py-3 text-sm font-medium hover:border-primary transition-colors cursor-pointer">
              <input
                class="h-4 w-4 text-primary border-slate-300 focus:ring-primary"
                type="radio"
                name="metodo_preferido"
                value="Mensaje de WhatsApp" />
              <span>Mensaje de WhatsApp</span>
            </label>
          </div>
        </div>

        <div>
          <label class="text-xs tracking-widest uppercase opacity-60">Link (si aplica)</label>
          <input
            class="mt-2 w-full bg-transparent border-b border-slate-300 focus:border-primary outline-none py-3"
            type="url"
            name="link"
            placeholder="https://..." />
        </div>

        <button class="btn btn-primary w-full">Enviar solicitud</button>

        <p class="text-center text-[10px] text-slate-500">
          Tus datos se usan solo para responder esta solicitud. Consulta nuestra
          <a class="underline" href="/legal/privacidad/">política de privacidad</a>
          .
        </p>
      </form>
    </div>
  </div>
</main>
