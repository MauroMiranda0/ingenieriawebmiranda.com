<header class="fixed w-full z-50 bg-background-light/80 backdrop-blur-md border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a class="flex items-center gap-4" href="/">
      <img alt="Ingeniería Web Miranda Logo" class="h-24 w-auto" src="/assets/img/logo.png"/>
    </a>
    <button class="md:hidden p-2 rounded-lg border border-slate-200 text-slate-700 hover:text-primary hover:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
            type="button" aria-label="Abrir menú" id="menu-toggle">
      <span class="material-icons" aria-hidden="true">menu</span>
    </button>
    <nav class="hidden md:flex items-center gap-10 font-medium text-sm tracking-widest uppercase">
      {% for item in navigation %}
      <a class="{% if item.type == 'cta' %}btn btn-primary{% else %}hover:text-primary transition-colors{% endif %} nav-link-tech"
         href="{{ item.href }}"
         {% if item.href in page.url and item.type != 'cta' %} aria-current="page"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
  <div class="md:hidden border-t border-slate-200 bg-background-light/95 backdrop-blur" id="mobile-menu" hidden>
    <nav class="flex flex-col gap-4 px-6 py-6 text-sm font-medium tracking-widest uppercase">
      {% for item in navigation %}
      <a class="{% if item.type == 'cta' %}btn btn-primary{% else %}hover:text-primary transition-colors{% endif %} nav-link-tech"
         href="{{ item.href }}"
         {% if item.href in page.url and item.type != 'cta' %} aria-current="page"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
</header>
