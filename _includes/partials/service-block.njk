<section id="{{ s.id }}" class="py-20 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <div>
        <p class="text-xs font-semibold tracking-[0.18em] uppercase text-slate-500">{{ s.eyebrow }}</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl text-primary">{{ s.title }}</h2>
        <p class="mt-4 text-base text-slate-600 leading-relaxed">{{ s.description }}</p>
      </div>
      <div class="order-first lg:order-last">
        <img
          src="/assets/img/{{ s.image }}"
          alt="{{ s.title }}"
          class="border border-slate-200 w-full"
          loading="lazy" />
      </div>
    </div>

    <div class="mt-12 grid md:grid-cols-3 gap-5">
      <article class="border border-slate-200 bg-white p-6 lg:p-8">
        <h3 class="font-display text-xl text-primary mb-4">Entregables</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          {% for item in s.deliverables %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </article>
      <article class="border border-slate-200 bg-white p-6 lg:p-8">
        <h3 class="font-display text-xl text-primary mb-4">Beneficios</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          {% for item in s.benefits %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </article>
      <article class="border border-slate-200 bg-white p-6 lg:p-8">
        <h3 class="font-display text-xl text-primary mb-4">Señales</h3>
        <ul class="space-y-2 text-sm text-slate-600">
          {% for item in s.signals %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </article>
    </div>

    <div class="mt-10">
      <h3 class="font-display text-xl text-primary mb-6">Áreas que cubrimos</h3>
      <div class="grid md:grid-cols-3 gap-5">
        {% for area in s.areas %}
        <div class="border border-slate-200 bg-white p-6">
          <h4 class="font-display text-lg text-primary mb-2">{{ area.heading }}</h4>
          <p class="text-sm text-slate-600 leading-relaxed">{{ area.content }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="mt-10 flex">
      <a class="btn btn-primary" href="/contacto/">Solicitar {{ s.eyebrow | lower }}</a>
    </div>
  </div>
</section>
