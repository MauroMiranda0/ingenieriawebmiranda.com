<main id="contenido-principal" class="pt-24">
  <section class="py-16 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs font-semibold tracking-[0.18em] uppercase text-slate-500">Caso</p>
      <h1 class="mt-3 font-display text-4xl md:text-6xl text-primary">{{ caseTitle }}</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-3xl">{{ caseDescription }}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-xs">
        {% for tag in caseTags %}
        <span class="px-3 py-1 border border-slate-200 bg-white text-slate-700">{{ tag }}</span>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="max-w-7xl mx-auto px-6 space-y-10">
      {% for section in caseSections %}
      <article class="border border-slate-200 bg-white p-8">
        <h2 class="font-display text-3xl text-primary mb-3">{{ section.heading }}</h2>
        {% if section.type == "list" %}
        <ul class="space-y-2 text-slate-600">
          {% for item in section.items %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="text-slate-600 leading-relaxed">{{ section.content }}</p>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="border border-slate-200 bg-white p-10">
        <h2 class="font-display text-3xl text-primary mb-3">¿Quieres un diagnóstico en tu contexto?</h2>
        <p class="text-slate-600 mb-8">{{ phrases.baselineDefendible }}</p>
        <a class="btn btn-primary" href="/contacto/">
          Solicitar diagnóstico
          <span class="material-icons text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>
</main>
