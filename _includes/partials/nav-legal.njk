<header class="border-b border-slate-200 bg-background-light/90 backdrop-blur">
  <div class="max-w-4xl mx-auto px-6 h-20 flex items-center justify-between">
    <a class="flex items-center gap-4" href="/">
      <img alt="Ingeniería Web Miranda Logo" class="h-12 w-auto" src="/assets/img/logo.png"/>
    </a>
    <button class="md:hidden p-2 rounded-lg border border-slate-200 text-slate-700 hover:text-primary hover:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary"
            type="button" aria-label="Abrir menú" id="menu-toggle">
      <span class="material-icons" aria-hidden="true">menu</span>
    </button>
    <nav class="hidden md:flex items-center gap-8 font-medium text-xs tracking-[0.3em] uppercase">
      <a class="hover:text-primary transition-colors nav-link-tech" href="/servicios/"{% if '/servicios/' in page.url %} aria-current="page"{% endif %}>Servicios</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/casos/"{% if '/casos/' in page.url %} aria-current="page"{% endif %}>Casos</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/metodo/"{% if '/metodo/' in page.url %} aria-current="page"{% endif %}>Método</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/recursos/"{% if '/recursos/' in page.url %} aria-current="page"{% endif %}>Recursos</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/proyectos/"{% if '/proyectos/' in page.url %} aria-current="page"{% endif %}>Proyectos</a>
      <a class="btn btn-primary nav-link-tech" href="/contacto/">Diagnóstico</a>
    </nav>
  </div>
  <div class="md:hidden border-t border-slate-200 bg-background-light/95 backdrop-blur" id="mobile-menu" hidden>
    <nav class="flex flex-col gap-4 px-6 py-6 text-sm font-medium tracking-widest uppercase">
      <a class="hover:text-primary transition-colors nav-link-tech" href="/servicios/"{% if '/servicios/' in page.url %} aria-current="page"{% endif %}>Servicios</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/casos/"{% if '/casos/' in page.url %} aria-current="page"{% endif %}>Casos</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/metodo/"{% if '/metodo/' in page.url %} aria-current="page"{% endif %}>Método</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/recursos/"{% if '/recursos/' in page.url %} aria-current="page"{% endif %}>Recursos</a>
      <a class="hover:text-primary transition-colors nav-link-tech" href="/proyectos/"{% if '/proyectos/' in page.url %} aria-current="page"{% endif %}>Proyectos</a>
      <a class="btn btn-primary nav-link-tech" href="/contacto/">Diagnóstico</a>
    </nav>
  </div>
</header>
