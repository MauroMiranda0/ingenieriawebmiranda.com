<nav aria-label="Breadcrumb" class="border-b border-slate-200 bg-white/80">
  <div class="max-w-7xl mx-auto px-6 py-2 text-xs text-slate-500">
    {% set trail = breadcrumbs[page.url] %} {% if trail %} {% for crumb in trail %} {% if crumb.url %}
    <a href="{{ crumb.url }}" class="hover:text-primary transition-colors">{{ crumb.label }}</a>
    {% else %}
    <span class="text-slate-900 font-medium" aria-current="page">{{ crumb.label }}</span>
    {% endif %} {% if not loop.last %}
    <span class="mx-1.5 text-slate-300" aria-hidden="true">/</span>
    {% endif %} {% endfor %} {% endif %}
  </div>
</nav>
